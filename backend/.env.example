PORT=5000

# Primary: local MongoDB (works on your Mac without internet/IP setup)
MONGO_URI=mongodb://127.0.0.1:27017/metrics_db

# Cloud MongoDB Atlas (your original accounts are stored here)
# When Atlas Network Access is fixed, swap MONGO_URI to this line:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xnwwrtd.mongodb.net/metrics_db?retryWrites=true&w=majority
MONGO_ATLAS_URI=mongodb+srv://<username>:<password>@cluster0.xnwwrtd.mongodb.net/metrics_db?retryWrites=true&w=majority

LOCAL_MONGO_URI=mongodb://127.0.0.1:27017/metrics_db
